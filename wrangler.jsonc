{
  // Cloudflare Worker configuration for the LinkedIn-X scuttlebutt dashboard.
  // The Worker serves the dashboard (static files in /public), exposes a small
  // JSON API, and stores everyone in a D1 database (binding: DB).
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "linkedin-x",
  "main": "src/worker.js",
  "compatibility_date": "2024-11-01",
  "observability": { "enabled": true },

  // Cloudflare Workers AI (built-in LLM). Used to write personalised outreach
  // reasons. Free daily allowance; the code falls back gracefully if it errors.
  "ai": { "binding": "AI" },

  // Daily refresh: re-research every tracked company so new senior ex-employees
  // appear automatically. Runs the scheduled() handler in src/worker.js.
  "triggers": {
    "crons": ["30 1 * * *"]
  },

  // Static dashboard. Assets are served first; anything under /api/* falls
  // through to the Worker in src/worker.js.
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },

  // D1 database. Create it once with:
  //   npx wrangler d1 create linkedinx
  // then paste the printed database_id below.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "linkedinx",
      "database_id": "799fcee5-6e48-4ba2-b18a-ccbb27e279a8",
      "migrations_dir": "migrations"
    }
  ]

  // Secrets (set with `npx wrangler secret put <NAME>`), not stored here:
  //   INGEST_TOKEN    -> shared password the dashboard uses to edit/add rows
  //                      and trigger a company search.
  //   SERPER_API_KEY  -> search API key. The Worker uses it to research a
  //                      company on demand (POST /api/search) and on the daily
  //                      cron. Without it, searches return "no_search_key".
  //                      (Alternatively GOOGLE_API_KEY + GOOGLE_CSE_ID.)
  //   MUNS_TOKEN      -> bearer token for the birdnest.muns.io stock search
  //                      (used by the /api/stock-search proxy for Add-company).
}
